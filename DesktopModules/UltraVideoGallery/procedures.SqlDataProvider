CREATE procedure {databaseOwner}{objectQualifier}UVG_SeriesAdjustOrder
	@videoId int,
	@moveDirection nvarchar(10)
AS

DECLARE @itemId int,@seriesIndex int, @seriesId int
DECLARE @_itemId int,@_seriesIndex int -- record to swap

if @moveDirection = 'Down'
BEGIN
	SELECT @itemId=ItemId, @seriesId=SeriesId,@seriesIndex=SeriesIndex from {databaseOwner}{objectQualifier}UVG_Video WHERE ItemId=@videoId
	SELECT TOP 1 @_itemId=Itemid,@_seriesIndex=SeriesIndex FROM {databaseOwner}{objectQualifier}UVG_Video WHERE SeriesId=@seriesId and SeriesIndex > @seriesIndex ORDER BY SeriesIndex ASC
	if isnull(@_itemId,0) > 0 
	begin
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = @seriesIndex where ItemId = @_itemId
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = @_seriesIndex where ItemId = @itemId
	end
END
else if @moveDirection = 'Up'
BEGIN
	SELECT @itemId=ItemId, @seriesId=SeriesId,@seriesIndex=SeriesIndex from {databaseOwner}{objectQualifier}UVG_Video WHERE ItemId=@videoId
	SELECT TOP 1 @_itemId=Itemid,@_seriesIndex=SeriesIndex FROM {databaseOwner}{objectQualifier}UVG_Video WHERE SeriesId=@seriesId and SeriesIndex < @seriesIndex ORDER BY SeriesIndex DESC
	if isnull(@_itemId,0) > 0
	begin
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = @seriesIndex where ItemId = @_itemId
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = @_seriesIndex where ItemId = @itemId
	end
END
else if @moveDirection = 'Bottom'
BEGIN
	DECLARE @max int
	SELECT @seriesId=SeriesId,@seriesIndex=SeriesIndex from {databaseOwner}{objectQualifier}UVG_Video WHERE ItemId=@videoId
	SELECT @max=max(SeriesIndex) FROM {databaseOwner}{objectQualifier}UVG_Video WHERE SeriesId=@seriesId
	if @seriesIndex < @max
	begin
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = SeriesIndex - 1 where SeriesId=@SeriesId and SeriesIndex > @seriesIndex
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = @max where ItemId = @videoId
	end
END
else if @moveDirection = 'Top'
BEGIN
	DECLARE @min int
	SELECT @seriesId=SeriesId,@seriesIndex=SeriesIndex from {databaseOwner}{objectQualifier}UVG_Video WHERE ItemId=@videoId
	--SELECT @min=min(SeriesIndex) FROM {databaseOwner}{objectQualifier}UVG_Video WHERE SeriesId=@seriesId
	SET @min=1
	if @seriesIndex > @min
	begin
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = SeriesIndex + 1 where SeriesId=@SeriesId and SeriesIndex < @seriesIndex
		update {databaseOwner}{objectQualifier}UVG_Video set SeriesIndex = @min where ItemId = @videoId
	end
END

GO



