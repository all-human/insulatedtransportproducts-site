CREATE procedure {databaseOwner}{objectQualifier}UVG_VideoSearchPlus
@PortalId int,
@LibraryId int,
@Categories varchar(500),
@Dates varchar(500),
@OrderType varchar(20)
AS

DECLARE @SQLString NVARCHAR(2000)
SET @SQLString = 'SELECT DISTINCT V.*, V.Views + V.Likes + V.TotalComments as Popularity FROM {databaseOwner}{objectQualifier}UVG_Video V Left Outer Join {databaseOwner}{objectQualifier}UVG_VideoCategory C on V.ItemId=C.VideoId Where V.Approved=1 '
if @LibraryId > 0
	SET @SQLString = @SQLString + '  And V.LibraryId=' + cast(@LibraryId as varchar(10))
else
	SET @SQLString = @SQLString + '  And V.PortalId=' + cast(@PortalId as varchar(10))

if len(@Categories) > 0
	if @LibraryId > 0
		SET @SQLString = @SQLString + ' and isnull(C.CategoryId,0) not in (''' + replace(@Categories, ',',''',''') + ''')'
	else
		SET @SQLString = @SQLString + ' and LibraryId not in (''' + replace(@Categories, ',',''',''') + ''')'

if len(@Dates) > 0
	SET @SQLString = @SQLString + ' and left(CONVERT(varchar(10), CreatedDate, 102),7) not in (''' + replace(@Dates, ',',''',''') + ''')'

