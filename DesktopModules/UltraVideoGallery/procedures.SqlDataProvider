CREATE PROCEDURE {databaseOwner}{objectQualifier}UVG_VideoEnsureCategory
	@VideoId int,
	@BelongedCategories varchar(200)
AS
	DECLARE @Offset int
	DECLARE @NextPosition int
	DECLARE @CategoryId int
	DECLARE @Categories varchar(200)

	Set @Categories = ',' + @BelongedCategories + ','
	
	begin transaction
	Set NoCount ON
	delete from {databaseOwner}{objectQualifier}UVG_VideoCategory where VideoId=@VideoId

	select @Offset = CharIndex(',',@Categories)
	select @NextPosition = CharIndex(',',@Categories,@Offset + 1)

	while @NextPosition > 0
	begin
		set @CategoryId=cast(SUBSTRING(@Categories,@Offset + 1,@NextPosition - @Offset - 1) as int)
		if @CategoryId > 0
			Insert into {databaseOwner}{objectQualifier}UVG_VideoCategory (VideoId,CategoryId) Values(@VideoId,@CategoryId)
		select @Offset = @NextPosition
		select @NextPosition = CharIndex(',',@Categories,@Offset + 1)
	end

	exec {databaseOwner}{objectQualifier}UVG_CategoryUpdateVideoCount
	
	--update {databaseOwner}{objectQualifier}UVG_Video set Categories = @BelongedCategories where ItemId = @VideoId
	Set NoCount OFF
	if @@error=0
	begin
		commit transaction
	end
	else
	begin
		rollback transaction
	end
GO



CREATE PROCEDURE {databaseOwner}{objectQualifier}UVG_VideoEnsureTag
	@VideoId int,
	@UserId int,
	@BelongedTags nvarchar(500)
AS
	DECLARE @Offset int
	DECLARE @NextPosition int
	DECLARE @Tags nvarchar(500)
	DECLARE @Tag nvarchar(200)
	DECLARE @TagId int
	DECLARE @PortalId int

	select @PortalId = PortalId from {databaseOwner}{objectQualifier}UVG_Video where ItemId = @VideoId
	Set @Tags = ',' + @BelongedTags + ','

	begin transaction
	Set NoCount ON
	delete from {databaseOwner}{objectQualifier}UVG_VideoTag where VideoId=@VideoId

	select @Offset = CharIndex(',',@Tags)
	select @NextPosition = CharIndex(',',@Tags,@Offset + 1)

	while @NextPosition > 0
	begin
		set @Tag= SUBSTRING(@Tags,@Offset + 1,@NextPosition - @Offset - 1)
		if @Tag <> ''
		begin
			set @TagId = 0
			select @TagId = ItemId from {databaseOwner}{objectQualifier}UVG_Tag where Tag = @Tag
			if isnull(@TagId, 0) =0 
			begin
				insert {databaseOwner}{objectQualifier}UVG_Tag (PortalId, Tag, IsPrivate, CreatedByUser, CreatedDate) values (@PortalId, @Tag, 0, @UserId, getdate())
				select @TagId =  SCOPE_IDENTITY()
			end 
			Insert into {databaseOwner}{objectQualifier}UVG_VideoTag (VideoId,TagId) Values(@VideoId,@TagId)
		end
		select @Offset = @NextPosition
		select @NextPosition = CharIndex(',',@Tags,@Offset + 1)
	end
	delete {databaseOwner}{objectQualifier}UVG_Tag where not exists(select * from {databaseOwner}{objectQualifier}UVG_VideoTag where {databaseOwner}{objectQualifier}UVG_VideoTag.TagId = {databaseOwner}{objectQualifier}UVG_Tag.ItemId)
	update {databaseOwner}{objectQualifier}UVG_Tag set VideoCount = (Select count(*) from {databaseOwner}{objectQualifier}UVG_VideoTag where TagId = {databaseOwner}{objectQualifier}UVG_Tag.ItemId) where PortalId = @PortalId
	
	Set NoCount OFF
	if @@error=0
	begin
		commit transaction
	end
	else
	begin
		rollback transaction
	end

GO



CREATE procedure {databaseOwner}{objectQualifier}UVG_VideoFreeSearch
@ScopeType varchar(20),
@Scope varchar(20),
@MaxResults int,
@FeaturedOnly bit,
@Timeline int,
@ListType varchar(20)
AS

if @MaxResults>0
	set rowcount @MaxResults

DECLARE @SQLString NVARCHAR(2000)
SET @SQLString = 'SELECT V.* FROM {databaseOwner}{objectQualifier}UVG_Video V Where V.Approved=1'

if @ScopeType = 'PORTAL'
	SET @SQLString = @SQLString + ' and V.PortalId=' + @Scope
else if @ScopeType = 'LIBRARY'
	SET @SQLString = @SQLString + ' and V.LibraryId=' + @Scope
else if @ScopeType = 'USER'
	SET @SQLString = @SQLString + ' and V.CreatedByUser=' + @Scope
else if @ScopeType = 'CATEGORY'
	SET @SQLString = @SQLString + ' and V.ItemId in (select VideoId from {databaseOwner}{objectQualifier}UVG_VideoCategory where CategoryId in (' + @Scope + '))'
else if @ScopeType = 'SERIES'
	SET @SQLString = @SQLString + ' and V.SeriesId=' + @Scope
else if @ScopeType = 'GROUP'
	SET @SQLString = @SQLString + ' and V.CreatedByUser in (Select UserId from {databaseOwner}{objectQualifier}UserRoles where RoleID = ' + @Scope + ')'

if @FeaturedOnly = 1
	SET @SQLString = @SQLString + ' and V.IsFeatured=1'

if @Timeline > 0
	SET @SQLString = @SQLString + ' and datediff(d, V.CreatedDate, getdate()) < ' + cast(@Timeline as varchar(10))

if @ListType = 'RecentVideos'
	SET @SQLString = @SQLString + ' Order By V.CreatedDate Desc'
else if @ListType = 'SpotLight'
	SET @SQLString = @SQLString + ' Order By newid() Desc'
else if @ListType = 'MostPopular'
	SET @SQLString = @SQLString + ' Order By V.Views + V.Likes + V.TotalComments Desc'
else if @ListType = 'MostViewed'
	SET @SQLString = @SQLString + ' Order By V.Views Desc'
else if @ListType = 'MostDiscussedd'
	SET @SQLString = @SQLString + ' Order By V.TotalComments Desc'
else if @ListType = 'TopRated'
	SET @SQLString = @SQLString + ' Order By V.Likes Desc'
else-- if @ListType = 'AlphabeticalOrder'
	SET @SQLString = @SQLString + ' Order By V.Title Asc'

EXECUTE sp_executesql @SQLString

GO




