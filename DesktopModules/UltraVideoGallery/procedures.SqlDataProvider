create function {databaseOwner}{objectQualifier}UVG_CommercialIsAppliable
(
@AudienceRoles nvarchar(200),
@ApplyTo bit,
@CurrentUserRoles nvarchar(200)
)
returns bit
as
BEGIN
	if ISNULL(@AudienceRoles, '') = ''
		return 1
	if @AudienceRoles = @CurrentUserRoles
		return @ApplyTo

	DECLARE @Offset int
	DECLARE @NextPosition int
	DECLARE @Role nvarchar(50)
	
	select @AudienceRoles = ','+@AudienceRoles+','
	select @CurrentUserRoles = ','+@CurrentUserRoles+','

	select @Offset = CharIndex(',',@AudienceRoles)
	select @NextPosition = CharIndex(',',@AudienceRoles,@Offset + 1)

	while @NextPosition > 0
	begin
		set @Role= SUBSTRING(@AudienceRoles,@Offset + 1,@NextPosition - @Offset - 1)
		if charindex(','+@Role+',', @CurrentUserRoles) > 0
			return @ApplyTo

		select @Offset = @NextPosition
		select @NextPosition = CharIndex(',', @AudienceRoles, @Offset + 1)
	end

	if @ApplyTo = 1
		return 0
	
	return 1
END
GO

create function {databaseOwner}{objectQualifier}UVG_CommercialIsActive
(
@StartDate SmallDateTime,
@EndDate SmallDateTime,
@CurrentDate SmallDateTime,
@MaxImpressions int,
@Impressions int,
@Criteria bit
)
returns bit
as
BEGIN
declare @dateCondition bit
if @StartDate > @CurrentDate or @EndDate < @CurrentDate
	set @dateCondition = 1
else
	set @dateCondition = 0

declare @impressionCondition bit
if @MaxImpressions <= @Impressions and (@MaxImpressions <> 0)
	set @impressionCondition = 1
else
	set @impressionCondition = 0

--@Criteria = 1 means "stop it(isActive = false) when both criteria is matched"
if @Criteria = 1
	if @dateCondition=1 and @impressionCondition=1
		return  0--Stopped
	else
		return 1
else
	if @dateCondition=1 or @impressionCondition=1
		return  0--Stopped
	else
		return 1
return 0
END
GO





























