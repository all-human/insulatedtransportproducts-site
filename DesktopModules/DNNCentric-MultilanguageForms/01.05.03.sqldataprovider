Create procedure {databaseOwner}[{objectQualifier}DCC_EF_InsertNewCategory] 
@ModuleID int,
@IsExpanded bit
as
declare @SortOrder int

set @SortOrder=(select  isnull (max(CategoryID),0)+1 from {databaseOwner}[{objectQualifier}DCC_EF_CategoryMaster])

Insert into {databaseOwner}[{objectQualifier}DCC_EF_CategoryMaster](ModuleID,SortOrder,IsExpanded) 
values(@ModuleID,@SortOrder,@IsExpanded )
SELECT NEW_CatID = SCOPE_IDENTITY()

