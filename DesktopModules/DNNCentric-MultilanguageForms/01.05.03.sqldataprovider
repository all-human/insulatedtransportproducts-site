CREATE view {databaseOwner}[{objectQualifier}DCC_EF_Category]
as
select 
	cm.CategoryID,
	cc.Culture,
	cc.CategoryName,
	cm.SortOrder,
	cm.ModuleID,
	cm.IsExpanded
from {databaseOwner}[{objectQualifier}DCC_EF_CategoryMaster] cm,{databaseOwner}[{objectQualifier}DCC_EF_CategoryCulture] cc
where cm.CategoryID=cc.CategoryID

