IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}DCC_EF_GetPostDataWorkFlowByCulture]') AND type in (N'P', N'PC'))
BEGIN
EXEC dbo.sp_executesql @statement = N'
CREATE procedure {databaseOwner}[{objectQualifier}DCC_EF_GetPostDataWorkFlowByCulture]
@Culture nvarchar(50)=''Any''

as
select * from {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_SQLPost]

where Culture=@Culture

' 
END
