ALTER procedure {databaseOwner}[{objectQualifier}DCC_EF_GetAvailableEmailTokens]
@ModuleID int
as
select distinct FieldName 
from {databaseOwner}[{objectQualifier}DCC_EF_EmailForm] ef,{databaseOwner}[{objectQualifier}DCC_EF_EmailFormCulture] cul
where
ef.FieldID=cul.FieldID 
AND
ef.Visible=1
AND
cul.Culture_Value like '%<validationType>3%'
AND
cul.Culture_Value like '%<required>true%'
AND 
ef.ModuleID=@ModuleID

-- 3 is for Email validation fields

