--DNNCentric_DCC_EF_FieldNameExistOrNot 'City' , 371
ALTER procedure {databaseOwner}[{objectQualifier}DCC_EF_FieldNameExistOrNot] 
@FieldName nvarchar(1000),
@ModuleID int
as
select count(*) from {databaseOwner}[{objectQualifier}DCC_EF_EmailForm] 
where FieldName=@FieldName
AND ModuleID=@ModuleID
AND IsDeleted='False'

