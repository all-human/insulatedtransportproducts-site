--Function
Alter function {databaseOwner}[{objectQualifier}DCC_EF_GetCategoryList] 
(
	@defaultLanguage as nvarchar(15),
	@currentLanguage as nvarchar(15),
	@ModuleID int
)
RETURNS TABLE 
AS
return
(
SELECT  TOP 100 PERCENT  
	A.CategoryID,
	isnull(B.CategoryName,A.CategoryName) CategoryName,
	A.SortOrder,
	A.IsExpanded
FROM
   (SELECT     
		CategoryID, 
		Culture, 
		CategoryName,
		SortORder,
        IsExpanded
	FROM	    	      
		{databaseOwner}{objectQualifier}DCC_EF_Category 
	WHERE      
		(Culture = @defaultLanguage AND ModuleID=@ModuleID)) 
AS A LEFT OUTER JOIN
	(SELECT     
		CategoryID, 
		Culture, 
		CategoryName,
		SortORder,
        IsExpanded
	FROM          
		{databaseOwner}{objectQualifier}DCC_EF_Category AS DCC_EF_Category_1 
	WHERE      
		(Culture = @currentLanguage AND ModuleID=@ModuleID)) 
AS B ON A.CategoryID = B.CategoryID
ORDER BY A.SortOrder
)


GO

