Alter procedure {databaseOwner}[{objectQualifier}DCC_EF_GetCategoryByCulture] 
@currentLanguage nvarchar(15),
@DefaultLanguage nvarchar(15),
@ModuleID int
as
SELECT     A.CategoryID,isnull(B.CategoryName,A.CategoryName) CategoryName,A.SortOrder,A.IsExpanded
FROM         (SELECT     CategoryID, Culture, CategoryName,SortOrder,IsExpanded
FROM          {databaseOwner}[{objectQualifier}DCC_EF_Category]
WHERE      (Culture = @defaultLanguage AND ModuleID=@ModuleID)) AS A LEFT OUTER JOIN
(SELECT     CategoryID, Culture, CategoryName,SortOrder,IsExpanded
FROM          {databaseOwner}[{objectQualifier}DCC_EF_Category] AS DCC_EF_Category_1 
WHERE      (Culture = @currentLanguage AND ModuleID=@ModuleID)) AS B ON A.CategoryID = B.CategoryID

order by A.SortOrder

