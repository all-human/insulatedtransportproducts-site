Alter procedure {databaseOwner}[{objectQualifier}DCC_EF_UpdateCategoryNameByCategoryID] 
@CategoryID int,
@Culture nvarchar(50),
@CategoryName nvarchar(4000),
@ModuleID int
AS

IF EXISTS (select Culture from {databaseOwner}[{objectQualifier}DCC_EF_Category] where CategoryID=@CategoryID AND Culture = @Culture AND ModuleID=@ModuleID) 
Begin
update
{databaseOwner}[{objectQualifier}DCC_EF_Category] 
set
Culture=@Culture,
CategoryName=@CategoryName
where
CategoryID=@CategoryID
AND Culture=@Culture
AND ModuleID=@ModuleID
End
ELSE
Begin
insert into
{databaseOwner}[{objectQualifier}DCC_EF_Category] 
(CategoryID,Culture,CategoryName,ModuleID)
values
(@CategoryID,@Culture,@CategoryName,@ModuleID)

End
