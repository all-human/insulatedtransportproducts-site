--select distinct sortorder,fieldname into #tmptable from {databaseOwner}[{objectQualifier}DCC_EF_SubmittedValues] order by sortorder

select * into #funtable 
from {databaseOwner}[{objectQualifier}DCC_EF_GetSubmissionDataAttributes](@FromDate,@ToDate,@FieldID,@StrSearchText,@ModuleID,@PageURL)
select distinct sortorder,fieldname into #tmptable 
FROM #funtable
 as A order by A.sortorder

DECLARE @cols NVARCHAR(max) 
SELECT  @cols = COALESCE(@cols + ',' + QUOTENAME(fieldname),QUOTENAME(fieldname))
FROM    (select * from #tmptable) as df

select @cols =(case when rtrim(ltrim(isnull(@cols,'')))='' then 'NoRecord' else @cols end)

DECLARE @Subquery NVARCHAR(max)

set @Subquery ='select FormRecordID as RecordID,'+ @cols + ' from (select FormRecordID ,fieldname,fieldvalue from #funtable as Q ) as P 
            pivot ( min(fieldvalue) for fieldname in ('+ @cols + ')) as pvt'

if(@SortColumn='') set @SortColumn='RecordID Desc'
declare @myQuery NVARCHAR(max)
set @myQuery= 'select ROW_NUMBER() OVER(ORDER BY '+ @SortColumn + ') as RowID,Sub.*
from ('+ @Subquery+')as Sub'

declare @finalQuery NVARCHAR(max)
set @finalQuery= 'select tbl.* from ('+@myQuery +')as tbl where RowID BETWEEN ('+ str(@StartPageIndex+1)+') AND ('+str(@StartPageIndex+ @PageSize)+')'

--print @finalQuery
exec (@finalQuery)

GO

