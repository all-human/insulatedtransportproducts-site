Alter Procedure {databaseOwner}[{objectQualifier}DCC_EF_GetFormSubmissionDataByPaging]
@FromDate datetime,
@ToDate DateTime,
@FieldID int,
@StrSearchText NVARCHAR(400),
@ModuleID int,
@SortColumn nvarchar(200),
@StartPageIndex int,
@PageSize int,
@PageURL nvarchar(500)
as
-- {databaseOwner}[{objectQualifier}DCC_EF_GetFormSubmissionDataByPaging] '10/26/2009','12/31/2009',-1,'tests asc',370,'',1,3 
-- {databaseOwner}[{objectQualifier}DCC_EF_GetFormSubmissionData] ' ',' ' 
