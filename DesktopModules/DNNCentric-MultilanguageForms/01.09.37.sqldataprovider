alter procedure {databaseOwner}[{objectQualifier}DCC_EF_FormValidationMasterAdd]
@FormValidationName nvarchar(250),
@FormValidationCondition nvarchar(max),
@moduleId int,
@Active bit,
@HighlightedfieldsName nvarchar(max)
as
declare @SortOrder int
set @SortOrder=(select  isnull (max(FormValidationId),0)+1 from {databaseOwner}[{objectQualifier}DCC_EF_FormValidationMaster])
declare @count int;
set @count=(select COUNT(*) from {databaseOwner}[{objectQualifier}DCC_EF_FormValidationMaster] where FormValidationName=@FormValidationName);

if(@count >0)
  begin
   select -2
  end 
 else
  begin  
	insert into {databaseOwner}[{objectQualifier}DCC_EF_FormValidationMaster]
	(
	FormValidationName,
	FormValidationCondition,	
	ModuleID,
	SortOrder,
	Active,
	HighlightFieldsName
	)
	Values
	(
	@FormValidationName,
	@FormValidationCondition ,	
	@moduleId,
	@SortOrder,
	@Active,
	@HighlightedfieldsName 
	)
	select SCOPE_IDENTITY()
end

GO

