alter procedure {databaseOwner}[{objectQualifier}DCC_EF_FormValidationMasterUpdate]
@FormValidationID int=3,
@FormValidationCondition nvarchar(max)=gfgfgg,
@moduleId int=383,
@active bit,
@HighlightedfieldsName nvarchar(max)
as
 Update {databaseOwner}[{objectQualifier}DCC_EF_FormValidationMaster]
  Set	
	FormValidationCondition=@FormValidationCondition,
	Active=@active,
	HighlightFieldsName=@HighlightedfieldsName
  where Moduleid=@moduleId and Formvalidationid=@FormValidationID

