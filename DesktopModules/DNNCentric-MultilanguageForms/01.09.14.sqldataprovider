ALTER procedure {databaseOwner}[{objectQualifier}DCC_EF_FormDataDelete] 

@RowID int,
@ModuleID int
as
if(@RowID<>0)
begin
delete from {databaseOwner}[{objectQualifier}DCC_EF_FormDataMaster] where FormRecordID=@RowID
end
else
begin
delete from {databaseOwner}[{objectQualifier}DCC_EF_FormDataMaster]
where ModuleID=@ModuleID
end 

