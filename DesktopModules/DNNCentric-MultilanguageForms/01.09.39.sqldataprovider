alter procedure {databaseOwner}[{objectQualifier}DCC_EF_UpdateEmailWorkFlowAdvancedSettings]
@WorkFlowId int=6,
@enableSettings bit=1,
@SMTPServerName nvarchar(500)='fdff',
@SMTPAuthentication int=1,
@SMTPEnableSSL bit=1,
@SMTPUserName nvarchar(500)='anjani',
@SMTPPassword nvarchar(500)='dfdf*******'
as
	update {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_EmailWorkFlowAdvancedSettings]
	set
	EnableSetting=@enableSettings,
	SMTPServerName=@SMTPServerName,
	SMTPAuthentication=@SMTPAuthentication,
	SMTPEnableSSL=@SMTPEnableSSL,
	SMTPUserName=@SMTPUserName	
	Where EWFAdvanceSettingID=(select EWFAdvanceSettingID from {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_SendEmail] where WorkFlowID=@WorkFlowId)
 
  if(@SMTPPassword <> '**********')
   Begin
   update {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_EmailWorkFlowAdvancedSettings]
	set
	SMTPPassword=@SMTPPassword   
	Where EWFAdvanceSettingID=(select EWFAdvanceSettingID from {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_SendEmail] where WorkFlowID=@WorkFlowId)
   end
GO

