alter procedure {databaseOwner}[{objectQualifier}DCC_EF_GetEmailWorkFlowAdvancedSettingsById]
@EmailWorkFlowId int=24
as

select AWS.* from  {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_EmailWorkFlowAdvancedSettings] as AWS inner join
               
               {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_SendEmail] as SEW on SEW.EWFAdvanceSettingID=AWS.EWFAdvanceSettingID
                and
               SEW.WorkFlowID=@EmailWorkFlowId

GO

