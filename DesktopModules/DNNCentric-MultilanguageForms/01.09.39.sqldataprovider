alter procedure {databaseOwner}[{objectQualifier}DCC_EF_UpdateSendEmailForAdvancedSettings]
@EmailWorkFlowId int,
@EWFAdvanceSettingID int
as

Update {databaseOwner}[{objectQualifier}DCC_EF_WorkFlow_SendEmail] 
          Set EWFAdvanceSettingID=@EWFAdvanceSettingID
          Where WorkFlowID=@EmailWorkFlowId

