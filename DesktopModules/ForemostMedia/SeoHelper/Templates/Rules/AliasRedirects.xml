<rule name="Alias Redirects" stopProcessing="true">
		<match url=".*" />
		<conditions logicalGrouping="MatchAll" trackAllCaptures="false">
			<add input="{HTTP_HOST}" pattern="^defaultinstall.com(.*)" />
			<add input="{REQUEST_URI}" pattern="^/.well-known/(.*)" negate="true" ignoreCase="true" />
		</conditions>
		<action type="Redirect" url="http://www.defaultinstall.com/{R:0}" appendQueryString="false" redirectType="Permanent" />
	</rule>
