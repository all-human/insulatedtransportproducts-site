					WHERE t.IndexId BETWEEN ((@pageNum - 1) * @pageSize + 1) AND (@pageNum * @pageSize)
					and [dbo].[fm_dist_ordering].TypeId = @typeId
					order by SortOrder, Company, LastName, FirstName
END
