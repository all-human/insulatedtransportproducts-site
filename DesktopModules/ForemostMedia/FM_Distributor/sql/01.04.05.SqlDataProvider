	CREATE VIEW dbo.fm_dist_ordering
	AS
	SELECT DISTINCT 
						  a.Id, a.Company, a.FirstName, a.LastName, a.Address, a.Address2, a.City, a.State, a.PostalCode, a.Country, a.Phone, a.Phone2, a.Cell, a.Fax, a.Email, a.Email2, 
						  a.Website, a.Description, a.Territory, a.PortalId, ISNULL(a.PriorityGroupId, - 1) AS UsersPGId, c.TypeId, ISNULL(d.SortOrder, 999999) AS SortOrder, 
						  CAST(CASE WHEN a.Country = 'US' THEN 1 ELSE 0 END AS BIT) AS IsUs
	FROM         dbo.fm_dist_Distributor AS a INNER JOIN
						  dbo.fm_dist_RegionCovering AS b ON a.Id = b.DistId INNER JOIN
						  dbo.fm_dist_DistributorType AS c ON a.Id = c.DistId LEFT OUTER JOIN
						  dbo.fm_dist_PriorityGroup AS d ON a.PriorityGroupId = d.Id
